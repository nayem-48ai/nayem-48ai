name: Build Android APK (Responsive & Obfuscated)

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Source Code
        uses: actions/checkout@v4

      - name: Extract App Metadata
        id: meta
        run: |
          APP_NAME=$(jq -r '.appName' assets/app-metadata.json)
          APP_PKG=$(jq -r '.appPackage' assets/app-metadata.json)
          APP_VER=$(jq -r '.versionName' assets/app-metadata.json)
          APP_CODE=$(jq -r '.versionCode' assets/app-metadata.json)
          PERMS=$(jq -r '.permissions | join(",")' assets/app-metadata.json)
          
          echo "name=$APP_NAME" >> $GITHUB_OUTPUT
          echo "package=$APP_PKG" >> $GITHUB_OUTPUT
          echo "version=$APP_VER" >> $GITHUB_OUTPUT
          echo "code=$APP_CODE" >> $GITHUB_OUTPUT
          echo "perms=$PERMS" >> $GITHUB_OUTPUT

      - name: Inject Update System into Root App.tsx
        run: |
          mkdir -p components
          curl -L --retry 5 --retry-delay 10 -o components/UpdateChecker.tsx https://raw.githubusercontent.com/nayem-48ai/nayem-48ai/refs/heads/tnx_bd/components/UpdateChecker.tsx
          
          if [ -f "App.tsx" ]; then
            if ! grep -q "import UpdateChecker" App.tsx; then
              sed -i "1i import UpdateChecker from './components/UpdateChecker';" App.tsx
            fi
            
            if ! grep -q "<UpdateChecker />" App.tsx; then
              sed -i '/<HashRouter>/a \      <UpdateChecker />' App.tsx || sed -i '/<Router>/a \      <UpdateChecker />' App.tsx
            fi
          fi

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install Dependencies & Build Web
        run: |
          npm install --no-package-lock
          npm install @capacitor/cli @capacitor/core @capacitor/android @capacitor/assets --no-package-lock
          npm run build
          npm install -g javascript-obfuscator
          javascript-obfuscator ./dist/assets --output ./dist/assets --compact true --self-defending true

      - name: Setup Java 21
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '21'

      - name: Initialize & Configure Capacitor Android
        run: |
          if [ ! -f "capacitor.config.ts" ] && [ ! -f "capacitor.config.json" ]; then
            npx cap init "${{ steps.meta.outputs.name }}" "${{ steps.meta.outputs.package }}" --web-dir dist
          fi

          if [ ! -d "android" ]; then
            npx cap add android
          fi

          if [ -f "assets/icon.png" ]; then
            npx capacitor-assets generate --android
          fi
          
          IFS=',' read -ra ADDR <<< "${{ steps.meta.outputs.perms }}"
          for i in "${ADDR[@]}"; do
            if ! grep -q "android.permission.$i" android/app/src/main/AndroidManifest.xml; then
              sed -i "/<\/manifest>/i \    <uses-permission android:name=\"android.permission.$i\" />" android/app/src/main/AndroidManifest.xml
            fi
          done

          sed -i '/dependencies {/a \    constraints {\n        implementation("org.jetbrains.kotlin:kotlin-stdlib-jdk7:1.8.22")\n        implementation("org.jetbrains.kotlin:kotlin-stdlib-jdk8:1.8.22")\n    }' android/app/build.gradle

          sed -i "s/versionCode [0-9]*/versionCode ${{ steps.meta.outputs.code }}/" android/app/build.gradle
          sed -i "s/versionName \"[^\"]*\"/versionName \"${{ steps.meta.outputs.version }}\"/" android/app/build.gradle
          
          if [ -f "android/app/src/main/res/values/strings.xml" ]; then
            sed -i "s/\"app_name\">.*<\/string>/\"app_name\">${{ steps.meta.outputs.name }}<\/string>/" android/app/src/main/res/values/strings.xml
          fi

          npx cap sync android

      - name: Build APK
        run: |
          cd android
          chmod +x gradlew
          ./gradlew assembleDebug --no-daemon

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          # এখানে নাম ফিক্স করা হয়েছে
          name: TNxBD-v${{ steps.meta.outputs.version }}
          path: android/app/build/outputs/apk/debug/app-debug.apk
