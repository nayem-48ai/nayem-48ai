name: Tnayem48 Universal Runner

on:
  push:
    branches:
      - main
  workflow_dispatch:
    inputs:
      action_type:
        description: 'Choose a professional task'
        required: true
        default: '-- Select Action --'
        type: choice
        options:
          - '-- Select Action --'
          - 'unzip & Build (normalize)'
          - 'Clean Repository'
          - 'Have a Look (Preview)'
          - 'unzip project (any zip files)'
          - 'Build/Normalize Project (Build Only)'
          - 'Convert Website to Android APK (urlTOapk)'
          - 'Build React Project to Android APK (reactTOapk)'

jobs:
  setup-guide:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
      - name: Update Guide README
        run: |
          mkdir -p .github
          curl -sL "https://raw.githubusercontent.com/nayem-48ai/nayem-48ai/refs/heads/tnx_bd/Guide" -o .github/README.md
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add .github/README.md
          git diff --quiet --staged || (git commit -m "docs: auto-sync setup guide" && git push origin main)

  virtual-execute:
    if: github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Setup Environment
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Setup Java 21 (For APK Build)
        if: contains(github.event.inputs.action_type, 'APK')
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '21'

      - name: Virtual Execution Engine
        id: executor
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          SELECTED_OPTION: ${{ github.event.inputs.action_type }}
        run: |
          if [[ "$SELECTED_OPTION" == "-- Select Action --" ]]; then
            echo "No action selected."
            exit 0
          fi

          declare -A ACTION_MAP
          ACTION_MAP["unzip & Build (normalize)"]="build"
          ACTION_MAP["Clean Repository"]="remove"
          ACTION_MAP["Have a Look (Preview)"]="preview"
          ACTION_MAP["unzip project (any zip files)"]="unzip"
          ACTION_MAP["Build/Normalize Project (Build Only)"]="build_only"
          ACTION_MAP["Convert Website to Android APK (urlTOapk)"]="urlTOapk"
          ACTION_MAP["Build React Project to Android APK (reactTOapk)"]="reactTOapk"

          ACTION_NAME=${ACTION_MAP["$SELECTED_OPTION"]}
          BASE_URL="https://raw.githubusercontent.com/nayem-48ai/nayem-48ai/refs/heads/tnx_bd"
          
          echo "🌐 Fetching Logic: $ACTION_NAME"

          curl -sL "$BASE_URL/$ACTION_NAME" | python3 -c "
          import yaml, sys, subprocess, os, json

          def load_metadata():
              paths = ['assets/url-metadata.json', 'assets/app-metadata.json']
              for p in paths:
                  if os.path.exists(p):
                      with open(p, 'r') as f:
                          return json.load(f)
              return {}

          meta = load_metadata()

          def replace_placeholders(script):
              pref, suff = '$' + '{{', '}}'
              placeholders = {
                  f'{pref} steps.meta.outputs.name {suff}': str(meta.get('appName', 'App')),
                  f'{pref} steps.meta.outputs.package {suff}': str(meta.get('appPackage', 'com.app.default')),
                  f'{pref} steps.meta.outputs.url {suff}': str(meta.get('appUrl', '')),
                  f'{pref} steps.meta.outputs.version {suff}': str(meta.get('versionName', '1.0.0')),
                  f'{pref} steps.meta.outputs.code {suff}': str(meta.get('versionCode', '1')),
              }
              for key, val in placeholders.items():
                  script = script.replace(key, val)
              return script

          def run_bash(script):
              script = replace_placeholders(script)
              if 'peaceiris/actions-gh-pages' in script:
                  deploy_script = \"\"\"
                  cd dist 2>/dev/null || cd .
                  git init
                  git config user.name 'github-actions[bot]'
                  git config user.email 'github-actions[bot]@users.noreply.github.com'
                  git add .
                  git commit -m 'deploy: virtual build push'
                  git push --force https://x-access-token:${GITHUB_TOKEN}@github.com/${GITHUB_REPOSITORY}.git master:tnx-bd
                  \"\"\"
                  subprocess.run(['bash', '-c', deploy_script], check=True)
              elif 'upload-artifact' in script or 'uses: actions/upload-artifact' in script:
                  # ভার্চুয়ালি আপলোড স্কিপ করা হবে কারণ পরবর্তী স্টেপ এটি হ্যান্ডেল করবে
                  print('Artifact detected: Scheduling automatic upload...')
                  return
              else:
                  subprocess.run(['bash', '-c', script], check=True)

          try:
              content = sys.stdin.read()
              if not content.strip(): sys.exit(0)
              data = yaml.safe_load(content)
              for job in data.get('jobs', {}).values():
                  for step in job.get('steps', []):
                      if 'run' in step:
                          run_bash(step['run'])
          except Exception as e:
              print(f'Execution Error: {e}'); sys.exit(1)
          "
          # আর্টফ্যাক্ট নাম সেট করা পরবর্তী স্টেপের জন্য
          if [[ "$SELECTED_OPTION" == *"APK"* ]]; then
            echo "upload_apk=true" >> $GITHUB_OUTPUT
          fi

      # ৩. APK আপলোড করা (শুধুমাত্র APK তৈরির ক্ষেত্রে)
      - name: Export Virtual APK
        if: steps.executor.outputs.upload_apk == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: TNxBD-Build-Artifact
          path: android/app/build/outputs/apk/debug/app-debug.apk
